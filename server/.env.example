# Template for server/.env — copy to server/.env and fill in.
# Real `.env` is gitignored. config.py loads it at import time; existing
# real environment variables (e.g. set by docker-compose, CI, or your shell)
# win over file contents.

# ===== Database =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=casemanage
DB_USER=postgres
DB_PASSWORD=change-me

# ===== Flask =====
FLASK_PORT=3002
FLASK_DEBUG=false

# ===== JWT =====
# REQUIRED in prod. Generate via: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me
JWT_EXPIRY_HOURS=24

# ===== CORS =====
# Comma-separated list of frontend origins allowed to call the API.
# Leave blank to disable CORS (production behind a reverse proxy can leave empty).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ===== Open API =====
# Which branch the public Open API exposes; almost always "main".
OPEN_API_BRANCH=main

# ===== AI chat / Agent integration =====
# Workspace root lives OUTSIDE the repo on purpose — see config.py comment.
# Default: ~/.check-manage/ai-workspaces
# AI_WORKSPACE_ROOT=/var/lib/check-manage/ai-workspaces
OPENCODE_BASE_URL=http://127.0.0.1:4096
MCP_SERVER_URL=http://127.0.0.1:3003
# MCP server bind address (used by mcp-server/main.py). Keep MCP_PORT in sync
# with the port in MCP_SERVER_URL / MCP_HEALTH_URL above.
MCP_HOST=127.0.0.1
MCP_PORT=3003
AI_SESSION_TTL_HOURS=24
AI_WORKSPACE_QUOTA_MB=200
# OpenCode model id: "<providerID>/<modelID>". The provider (with its API key)
# is configured in OpenCode's own global config, not here.
OPENCODE_MODEL=mimo/mimo-v2.5

# ===== Reverse proxy (production, server/proxy.py) =====
# Public listen address of the reverse proxy.
PROXY_HOST=0.0.0.0
PROXY_PORT=8080
# Where the proxy reaches the Flask backend; its PORT is also the port the proxy
# launches the backend on (so they can't drift). FLASK_PORT only governs the
# standalone dev server (npm run server).
BACKEND_URL=http://127.0.0.1:3001
# MCP server health endpoint the proxy probes on startup.
MCP_HEALTH_URL=http://127.0.0.1:3003/health
# Optional: explicit interpreter for the MCP server's own venv; auto-probed if unset.
# MCP_PYTHON=
