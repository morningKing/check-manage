{
  "name": "check-manage",
  "version": "1.0.0",
  "description": "巡检用例管理系统 - 支持动态菜单配置和动态表单定制",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "server": "cd server && python app.py",
    "server:init": "cd server && python init_db.py",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "cd server && set PYTEST_DISABLE_PLUGIN_AUTOLOAD=1 && python -m pytest -v",
    "test:all": "npm run test:server && npm run test",
    "start": "bash start.sh",
    "start:skip-build": "bash start.sh --skip-build"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@element-plus/icons-vue": "^2.3.1",
    "@univerjs/preset-sheets-core": "^0.16.1",
    "@univerjs/preset-sheets-filter": "^0.16.1",
    "@univerjs/presets": "^0.16.1",
    "@vueup/vue-quill": "^1.2.0",
    "axios": "^1.6.8",
    "codemirror": "^6.0.2",
    "echarts": "^6.0.0",
    "element-plus": "^2.6.1",
    "force-graph": "^1.51.1",
    "pinia": "^2.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rxjs": "^7.8.2",
    "uuid": "^9.0.1",
    "vue": "^3.4.21",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.3.0",
    "vuedraggable": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^8.2.2",
    "jsdom": "^28.1.0",
    "json-server": "^0.17.4",
    "sass": "^1.71.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.0.6"
  }
}
