  "pageConfigs": [
    {
      "id": "page-inspection-case",
      "name": "巡检用例",
      "description": "巡检用例管理页面",
      "apiEndpoint": "/api/data/inspection-case",
      "fields": [
        {
          "id": "field-1",
          "label": "用例名称",
          "fieldName": "caseName",
          "controlType": "text",
          "required": true,
          "order": 1,
          "placeholder": "请输入用例名称"
        },
        {
          "id": "field-2",
          "label": "用例类型",
          "fieldName": "caseType",
          "controlType": "select",
          "required": true,
          "order": 2,
          "placeholder": "请选择用例类型",
          "options": [
            { "label": "硬件巡检", "value": "hardware" },
            { "label": "软件巡检", "value": "software" },
            { "label": "网络巡检", "value": "network" },
            { "label": "安全巡检", "value": "security" }
          ],
          "optionsSource": { "type": "static" }
        },
        {
          "id": "field-3",
          "label": "优先级",
          "fieldName": "priority",
          "controlType": "select",
          "required": true,
          "order": 3,
          "placeholder": "请选择优先级",
          "options": [
            { "label": "高", "value": "high" },
            { "label": "中", "value": "medium" },
            { "label": "低", "value": "low" }
          ],
          "optionsSource": { "type": "static" }
        },
        {
          "id": "field-4",
          "label": "巡检项目",
          "fieldName": "checkItems",
          "controlType": "multiSelect",
          "required": false,
          "order": 4,
          "placeholder": "请选择巡检项目",
          "options": [
            { "label": "CPU使用率", "value": "cpu" },
            { "label": "内存使用率", "value": "memory" },
            { "label": "磁盘空间", "value": "disk" },
            { "label": "网络连接", "value": "network" },
            { "label": "服务状态", "value": "service" }
          ],
          "optionsSource": { "type": "static" }
        },
        {
          "id": "field-5",
          "label": "用例描述",
          "fieldName": "description",
          "controlType": "textarea",
          "required": false,
          "order": 5,
          "placeholder": "请输入用例描述"
        },
        {
          "id": "field-6",
          "label": "附件",
          "fieldName": "attachments",
          "controlType": "file",
          "required": false,
          "order": 6,
          "placeholder": "请上传附件"
        }
      ],
      "createdAt": "2024-01-01T00:00:00.000Z",
      "updatedAt": "2024-01-01T00:00:00.000Z"
    },
    {
