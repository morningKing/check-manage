          "controlType": "date",
          "required": false,
          "order": 4,
          "placeholder": "请选择结束日期"
        },
        {
          "id": "field-p5",
          "label": "负责人",
          "fieldName": "owner",
          "controlType": "text",
          "required": true,
          "order": 5,
          "placeholder": "请输入负责人姓名"
        },
        {
          "id": "field-p6",
          "label": "计划描述",
          "fieldName": "description",
          "controlType": "textarea",
          "required": false,
          "order": 6,
          "placeholder": "请输入计划描述"
